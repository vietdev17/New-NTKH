{
  "name": "furniture-vn",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "backend": "cd apps/backend && npm run start:dev",
    "frontend": "cd apps/fe && npm run dev",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
